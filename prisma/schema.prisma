generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CREATOR
  COMPANY
}

enum MembershipRole {
  OWNER
  ADMIN
  EDITOR
  VIEWER
}

enum PostAuthorType {
  CREATOR
  COMPANY
}

enum TypeCooperation {
  ONE_TIME
  LONG_TIME
}

enum PostContentType {
  PHOTO
  VIDEO
  PHOTO_VIDEO
}

enum ApplicationStatus {
  NEW
  VIEWED
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum TaskStatus {
  PREPARING
  PENDING_APPROVAL
  IN_PROGRESS
  CHECKING
  REVISION
  COMPLETED
  CANCELLED
}

enum TaskActivityType {
  STATUS_CHANGED
  FIELD_UPDATED
  MEDIA_ADDED
  MEDIA_REMOVED
}

enum TaskMediaKind {
  MAIN
  REPORT
}

model Account {
  id          String              @id @default(uuid())
  email       String              @unique
  password    String
  memberships AccountMembership[]
  invites     AccountInvite[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model AccountMembership {
  id        String         @id @default(uuid())
  accountId String
  userId    String
  role      MembershipRole
  account   Account        @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([accountId, userId])
  @@index([userId])
}

model AccountInvite {
  id         String         @id @default(uuid())
  userId     String
  inviterId  String
  email      String
  role       MembershipRole
  token      String         @unique
  expiresAt  DateTime
  acceptedAt DateTime?
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  inviter    Account        @relation(fields: [inviterId], references: [id], onDelete: Cascade)
  createdAt  DateTime       @default(now())

  @@index([email])
  @@index([userId])
}

model User {
  id                       String                    @id @default(uuid())
  email                    String
  role                     Role
  creatorProfile           CreatorProfile?
  companyProfile           CompanyProfile?
  memberships              AccountMembership[]
  invites                  AccountInvite[]
  conversationParticipants ConversationParticipant[]
  sentMessages             Message[]
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  contacts                 Json?
  person                   Json?
  phone                    String?
  location                 String?
  avatar                   String?
  bio                      String?
  followers                Int                       @default(0)
  aboutMe                  String?
  banner                   String?
  posts                    Post[]
  favoriteGroups           FavoriteGroup[]
  favoritePosts            FavoritePost[]
  applications             PostApplication[] @relation("PostApplications")
  ownedTasks               Task[]            @relation("OwnedTasks")
  executedTasks            Task[]            @relation("ExecutedTasks")
  taskComments             TaskComment[]
  taskActivities           TaskActivity[]
}

model Conversation {
  id           String                    @id @default(uuid())
  participants ConversationParticipant[]
  messages     Message[]
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
}

model ConversationParticipant {
  id             String       @id @default(uuid())
  conversationId String
  userId         String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String         @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  createdAt      DateTime       @default(now())
  conversation   Conversation   @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User           @relation(fields: [senderId], references: [id], onDelete: Cascade)
  media          MessageMedia[]

  @@index([conversationId, createdAt])
}

model MessageMedia {
  id        String   @id @default(uuid())
  messageId String
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  url       String
  key       String
  size      String
  mimeType  String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([messageId])
}

model CreatorProfile {
  id       String @id @default(uuid())
  userId   String @unique
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  name     String
  lastName String
}

model CompanyProfile {
  id          String @id @default(uuid())
  userId      String @unique
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName String
}

model Post {
  id              String            @id @default(uuid())
  permissions     String[]          @default([])
  title           String
  ownerId         String
  owner           User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  chips           String[]          @default([])
  description     String            @default("")
  typeCooperation TypeCooperation[]
  urgent          Boolean           @default(false)
  contentType     PostContentType
  photoCount      String            @default("0")
  videoCount      String            @default("0")
  finalPrice      String            @default("")
  rangePrice      String[]          @default([])
  isArchived      Boolean           @default(false)
  keyWords        String[]          @default([])
  categories      String[]          @default([])
  type            PostAuthorType
  media           PostMedia[]
  favorites       FavoritePost[]
  applications    PostApplication[]
  tasks           Task[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([ownerId])
  @@index([isArchived])
}

model PostMedia {
  id        String   @id @default(uuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  url       String
  key       String
  size      String
  mimeType  String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([postId])
}

model FavoriteGroup {
  id        String         @id @default(uuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  favorites FavoritePost[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([userId, name])
  @@index([userId])
}

model FavoritePost {
  id        String         @id @default(uuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String
  post      Post           @relation(fields: [postId], references: [id], onDelete: Cascade)
  groupId   String?
  group     FavoriteGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  createdAt DateTime       @default(now())

  @@unique([userId, postId])
  @@index([userId])
  @@index([groupId])
}

model PostApplication {
  id          String            @id @default(uuid())
  postId      String
  post        Post              @relation(fields: [postId], references: [id], onDelete: Cascade)
  applicantId String
  applicant   User              @relation("PostApplications", fields: [applicantId], references: [id], onDelete: Cascade)
  message     String
  status      ApplicationStatus @default(NEW)
  task        Task?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([postId, applicantId])
  @@index([postId])
  @@index([applicantId])
  @@index([status])
}

model Task {
  id            String          @id @default(uuid())
  applicationId String          @unique
  application   PostApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  postId        String
  post          Post            @relation(fields: [postId], references: [id], onDelete: Cascade)
  ownerId       String
  owner         User            @relation("OwnedTasks", fields: [ownerId], references: [id], onDelete: Cascade)
  executorId    String
  executor      User            @relation("ExecutedTasks", fields: [executorId], references: [id], onDelete: Cascade)
  status        TaskStatus      @default(PREPARING)
  description   String          @default("")
  finalDate     DateTime?
  photoCount    String          @default("0")
  videoCount    String          @default("0")
  urgent        Boolean         @default(false)
  media         TaskMedia[]
  comments      TaskComment[]
  activities    TaskActivity[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([ownerId])
  @@index([executorId])
  @@index([status])
}

model TaskComment {
  id        String             @id @default(uuid())
  taskId    String
  task      Task               @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId  String
  author    User               @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content   String
  media     TaskCommentMedia[]
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@index([taskId])
}

model TaskCommentMedia {
  id        String      @id @default(uuid())
  commentId String
  comment   TaskComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  url       String
  key       String
  size      String
  mimeType  String
  sortOrder Int         @default(0)
  createdAt DateTime    @default(now())

  @@index([commentId])
}

model TaskMedia {
  id        String        @id @default(uuid())
  taskId    String
  task      Task          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  kind      TaskMediaKind @default(MAIN)
  url       String
  key       String
  size      String
  mimeType  String
  sortOrder Int           @default(0)
  createdAt DateTime      @default(now())

  @@index([taskId])
  @@index([taskId, kind])
}

model TaskActivity {
  id        String           @id @default(uuid())
  taskId    String
  task      Task             @relation(fields: [taskId], references: [id], onDelete: Cascade)
  actorId   String
  actor     User             @relation(fields: [actorId], references: [id], onDelete: Cascade)
  type      TaskActivityType
  payload   Json
  createdAt DateTime         @default(now())

  @@index([taskId, createdAt])
}
